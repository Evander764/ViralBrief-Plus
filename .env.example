# ============================================================
# 爆款选题雷达 Local —— 可选环境变量
# 复制为 .env 即可生效。所有项都有合理默认值，通常无需修改。
# API Key 不要写在这里，请在桌面端「设置」里填写（会加密存储）。
# ============================================================

# 本地服务监听端口（默认 8787）。设为 0 表示随机端口。
VBP_PORT=8787

# 本地数据目录（数据库 / 截图 / 导出 / 配置）。默认是项目下的 ./data
# VBP_DATA_DIR=/absolute/path/to/data

# 启动时是否自动打开浏览器仪表盘（true/false，默认 true）
VBP_OPEN_BROWSER=true

# 旧的 VB_PORT / VB_DATA_DIR / VB_OPEN_BROWSER 仍兼容，新配置优先使用 VBP_*。
